@model IEnumerable<EventEase.Models.Venue>
@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-5">Available Venues</h1>
    @if (User.IsInRole("Admin"))
    {
        <p><a asp-action="Create" class="btn btn-primary">Add New Venue</a></p>
    }
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x200" : item.ImageUrl)"
                     class="card-img-top" alt="@item.VenueName" style="height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">@item.VenueName</h5>
                    <p class="card-text text-muted"><i class="bi bi-geo-alt"></i> @item.Location</p>
                    <p class="badge bg-info text-dark">Capacity: @item.Capacity</p>
                </div>
                <div class="card-footer bg-white border-0 d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-primary">View Details</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <div>
                            <a asp-action="Edit" asp-route-id="@item.VenueId" class="text-warning me-2"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.VenueId" class="text-danger"><i class="bi bi-trash"></i></a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>