@model EventEase.Models.Venue
@{
    ViewData["Title"] = "Venue Details";
}

<div class="container glass-card" style="max-width: 800px;">
    <div class="row">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="col-12 mb-4 text-center">
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow" style="max-height: 400px; width: 100%; object-fit: cover;" />
            </div>
        }
        <div class="col-md-12 text-center mb-4">
            <h1 class="display-5 fw-bold">@Model.VenueName</h1>
        </div>
        <div class="col-md-6">
            <p><strong>Location:</strong> @Model.Location</p>
        </div>
        <div class="col-md-6 text-end">
            <p><strong>Capacity:</strong> @Model.Capacity people</p>
        </div>
    </div>
    <hr />
    <div class="d-flex justify-content-between mt-4">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-primary px-5">Edit Venue</a>
        }
    </div>
</div>