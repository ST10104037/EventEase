@model EventEase.Models.Event
@{
    ViewData["Title"] = "Event Details";
}

<div class="container glass-card" style="max-width: 800px;">
    <div class="row">
        <div class="col-md-12 text-center mb-4">
            <h1 class="display-5 fw-bold">@Model.EventName</h1>
            <span class="badge bg-primary px-3 py-2">ID: #@Model.EventId</span>
        </div>
        <div class="col-md-6">
            <div class="mb-4">
                <label class="text-white-50 small text-uppercase fw-bold">Date & Time</label>
                <h4 class="fw-light">@Model.EventDate.ToString("f")</h4>
            </div>
            <div class="mb-4">
                <label class="text-white-50 small text-uppercase fw-bold">Venue</label>
                <h4>@Model.Venue?.VenueName</h4>
            </div>
        </div>
        <div class="col-md-6">
            <label class="text-white-50 small text-uppercase fw-bold">Description</label>
            <p class="lead">@Model.Description</p>
        </div>
    </div>
    <hr />
    <div class="d-flex justify-content-between mt-4">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-primary px-5">Edit Event</a>
    </div>
</div>
