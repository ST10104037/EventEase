@model EventEase.Models.Event
@{
    ViewData["Title"] = "Delete Event";
}

<div class="container glass-card text-center" style="max-width: 500px;">
    <h2 class="text-danger">⚠️ Warning</h2>
    <p>Are you sure you want to permanently delete <strong>@Model.EventName</strong>?</p>
    <hr />
    <form asp-action="Delete">
        <input type="hidden" asp-for="EventId" />
        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-danger">Yes, Delete Event</button>
            <a asp-action="Index" class="btn btn-outline-light">No, Go Back</a>
        </div>
    </form>
</div>