@model IEnumerable<EventEase.Models.Venue>
@{
    ViewData["Title"] = "Welcome";
}

<!-- Hero Search Section -->
<div class="text-center py-5 glass-card mb-5">
    <h1 class="display-3 fw-bold text-white">Find Your Perfect Space</h1>
    <p class="lead text-white-50">Explore venues, check capacity, and plan your event.</p>

    <form asp-action="Index" method="get" class="mt-4 mx-auto" style="max-width: 600px;">
        <div class="input-group input-group-lg">
            <input type="text" name="searchString" class="form-control border-0 shadow-none" placeholder="Search by name or location...">
            <button class="btn btn-primary px-4" type="submit"><i class="bi bi-search"></i></button>
        </div>
    </form>
</div>

<!-- Venues Gallery -->
<h2 class="text-white mb-4">📍 Featured Venues</h2>
<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-lg glass-card overflow-hidden">
                <img src="@item.ImageUrl" class="card-img-top" style="height: 220px; object-fit: cover;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h4 class="fw-bold">@item.VenueName</h4>
                        <span class="badge @(item.IsAvailable ? "bg-success" : "bg-danger")">
                            @(item.IsAvailable ? "Available" : "Booked")
                        </span>
                    </div>
                    <p class="text-white-50 small"><i class="bi bi-geo-alt"></i> @item.Location</p>
                    <hr class="border-secondary">
                    <div class="row text-center mb-3">
                        <div class="col-6 border-end border-secondary">
                            <small class="d-block text-uppercase text-white-50">Capacity</small>
                            <strong>@item.Capacity</strong>
                        </div>
                        <div class="col-6">
                            <small class="d-block text-uppercase text-white-50">Contact</small>
                            <small>@item.ContactPhone</small>
                        </div>
                    </div>
                    <a asp-controller="Venues" asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-outline-light w-100">View Full Details</a>
                </div>
            </div>
        </div>
    }
</div>