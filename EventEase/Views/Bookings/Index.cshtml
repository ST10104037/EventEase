@model IEnumerable<EventEase.Models.Booking>
@{
    ViewData["Title"] = "Manage Bookings";
}

<div class="container glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📅 @ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">➕ New Booking</a>
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search bookings..." />
            <button type="submit" class="btn btn-secondary">Search</button>
            <a asp-action="Index" class="btn btn-outline-light ms-2">Clear</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Event</th>
                    <th>Venue</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.BookingDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="bi bi-geo-alt">@item.Event?.EventName</span></td>
                        <td><span class="bi bi-geo-alt">@item.Venue?.VenueName</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-outline border-0"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-outline-dark border-0"><i class="bi bi-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>  
        </table>
    </div>
</div>