@model EventEase.Models.Booking
@{
    ViewData["Title"] = ViewContext.RouteData.Values["action"].ToString() == "Create" ? "New Booking" : "Edit Booking";
}

<div class="container glass-card" style="max-width: 600px;">
    <h1 class="text-center">@ViewData["Title"]</h1>
    <p class="text-center text-white-50">Fill in the details to secure the venue.</p>
    <hr />
    <form asp-action="@ViewContext.RouteData.Values["action"]">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        @if (ViewData["Title"].ToString() == "Edit Booking")
        {
            <input type="hidden" asp-for="BookingId" />
        }

        <div class="form-floating mb-3">
            <select asp-for="EventId" class="form-control" asp-items="ViewBag.EventId"></select>
            <label asp-for="EventId">Select Event</label>
        </div>

        <div class="form-floating mb-3">
            <select asp-for="VenueId" class="form-control" asp-items="ViewBag.VenueId"></select>
            <label asp-for="VenueId">Select Venue</label>
        </div>

        <div class="form-floating mb-4">
            <input asp-for="BookingDate" class="form-control" type="date" />
            <label asp-for="BookingDate">Booking Date</label>
            <span asp-validation-for="BookingDate" class="text-danger"></span>
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary btn-lg">@(ViewData["Title"].ToString() == "New Booking" ? "Create Booking" : "Save Changes")</button>
            <a asp-action="Index" class="btn btn-link text-white">Cancel and Go Back</a>
        </div>
    </form>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}