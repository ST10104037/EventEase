@page
@model LogoutModel
@{
    ViewData["Title"] = "Signed Out";
}

<div class="container glass-card text-center">
    <header>
        <h1>👋 @ViewData["Title"]</h1>
        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <p class="lead">Are you sure you want to log out?</p>
                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="btn btn-lg btn-secondary">Confirm Logout</button>
                </form>
            }
            else
            {
                <p class="lead">You have been successfully logged out. See you next time!</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Return to Home</a>
            }
        }
    </header>
</div>