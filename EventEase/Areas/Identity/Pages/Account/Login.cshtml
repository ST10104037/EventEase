@page
@model LoginModel
@{
    ViewData["Title"] = "Welcome Back";
}

<div class="container glass-card">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <section>
                <form id="account" method="post">
                    <h1 class="text-center">🔑 @ViewData["Title"]</h1>
                    <p class="text-center">Log in to manage your venues and bookings.</p>
                    <hr />
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
                        <label asp-for="Input.Password">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="checkbox mb-3">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            Keep me logged in
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary mb-3">Sign In</button>

                    <div class="text-center small">
                        <p><a id="forgot-password" asp-page="./ForgotPassword" class="text-white">Forgot your password?</a></p>
                        <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-white">Don't have an account? Register</a></p>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}